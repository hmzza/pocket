generator client {
  provider      = "prisma-client-js"
  binaryTargets  = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  POS_STAFF
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  WATCH_LATER
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  CASH
  CARD
  JAZZCASH
  EASYPAISA
  FOODPANDA_PAYOUT
}

enum OrderChannel {
  ONLINE
  POS
}

enum ServiceType {
  DELIVERY
  TAKEAWAY
  DINE_IN
  INSHOP
  FOODPANDA
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum NotificationType {
  ORDER
  STOCK
  CUSTOMER
  CMS
}

enum InventoryTransactionType {
  PURCHASE
  CONSUMPTION
  ADJUSTMENT
  WASTAGE
  RETURN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model Role {
  id        String   @id @default(cuid())
  code      RoleCode @unique
  label     String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String         @id @default(cuid())
  roleId        String
  name          String
  username      String         @unique
  email         String         @unique
  phone         String?        @unique
  passwordHash  String
  avatarUrl     String?
  isActive      Boolean        @default(true)
  canAccessAdmin Boolean       @default(false)
  canAccessPos   Boolean       @default(false)
  lastLoginAt   DateTime?
  marketingOptIn Boolean      @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          Role           @relation(fields: [roleId], references: [id])
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  favorites     Favorite[]
  notifications Notification[]
  auditLogs     AuditLog[]
  cart          ShoppingCart?
  inventoryTransactions InventoryTransaction[] @relation("InventoryActor")
  expenses      Expense[]     @relation("ExpenseActor")
  moneyTransfers MoneyTransfer[] @relation("MoneyTransferActor")
  dailyClosings DailyClosing[] @relation("DailyClosingActor")
  loans         Loan[]        @relation("LoanActor")
  loanRepayments LoanRepayment[] @relation("LoanRepaymentActor")
}

model Branch {
  id             String           @id @default(cuid())
  slug           String           @unique
  name           String
  city           String
  addressLine1   String
  addressLine2   String?
  phone          String
  email          String?
  latitude       Float?
  longitude      Float?
  deliveryFee    Decimal          @db.Decimal(10, 2)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  hours          BranchHours[]
  products       BranchProduct[]
  carts          ShoppingCart[]
  orders         Order[]
  inventories    BranchInventory[]
  expenses       Expense[]
  moneyTransfers MoneyTransfer[]
  dailyClosings  DailyClosing[]
  loans          Loan[]
  loanRepayments LoanRepayment[]
}

model BranchHours {
  id        String   @id @default(cuid())
  branchId  String
  dayOfWeek Int
  openTime  String
  closeTime String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  imageUrl    String?
  products    Product[]
  packagingRules PackagingRule[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
    id               String             @id @default(cuid())
    categoryId       String
    slug             String             @unique
    sku              String             @unique
    name             String
    description      String
    ingredients      String[]
    nutritionInfo    Json?
    basePrice        Decimal            @db.Decimal(10, 2)
    compareAtPrice   Decimal?           @db.Decimal(10, 2)
    calories         Int?
    featured         Boolean            @default(false)
    bestSeller       Boolean            @default(false)
    isActive         Boolean            @default(true)
    sortOrder        Int                @default(0)
    stockStatus      String             @default("IN_STOCK")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  category         Category           @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  addOnGroups      AddOnGroup[]
  bundleComponents ProductBundleComponent[] @relation("BundleProduct")
  bundledIn        ProductBundleComponent[] @relation("BundleComponentProduct")
  orderItemBundleComponents OrderItemBundleComponent[] @relation("OrderItemBundleComponentProduct")
  branchPricing    BranchProduct[]
  reviews          Review[]
  favorites        Favorite[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  productIngredients ProductIngredient[]
  packagingRules   PackagingRule[]
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String
  alt        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AddOnGroup {
  id          String        @id @default(cuid())
  productId   String
  name        String
  minSelect   Int           @default(0)
  maxSelect   Int           @default(1)
  isRequired  Boolean       @default(false)
  sortOrder   Int           @default(0)
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  options     AddOnOption[]
}

model AddOnOption {
  id          String      @id @default(cuid())
  groupId     String
  name        String
  priceDelta  Decimal     @db.Decimal(10, 2)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  group       AddOnGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItems  OrderItemAddOn[]
}

model ProductBundleComponent {
  id                 String  @id @default(cuid())
  productId          String
  componentProductId  String
  quantity           Int     @default(1)
  sortOrder          Int     @default(0)
  product            Product @relation("BundleProduct", fields: [productId], references: [id], onDelete: Cascade)
  componentProduct   Product @relation("BundleComponentProduct", fields: [componentProductId], references: [id], onDelete: Cascade)

  @@unique([productId, componentProductId])
}

model BranchProduct {
  id          String   @id @default(cuid())
  branchId    String
  productId   String
  price       Decimal  @db.Decimal(10, 2)
  isAvailable Boolean  @default(true)
  stockStatus String   @default("IN_STOCK")
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
}

model Address {
  id            String    @id @default(cuid())
  userId        String
  label         String?
  addressLine1  String
  addressLine2  String?
  city          String
  instructions  String?
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
}

model ShoppingCart {
  id         String     @id @default(cuid())
  userId     String     @unique
  branchId   String
  updatedAt  DateTime   @updatedAt
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch     Branch     @relation(fields: [branchId], references: [id])
  items      CartItem[]
}

model CartItem {
  id               String       @id @default(cuid())
  cartId           String
  productId        String
  quantity         Int          @default(1)
  note             String?
  selectedAddOnIds String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  cart             ShoppingCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  title          String
  description    String?
  type           DiscountType
  value          Decimal      @db.Decimal(10, 2)
  minOrderValue  Decimal?     @db.Decimal(10, 2)
  usageLimit     Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  orders         Order[]
}

model Order {
  id                  String         @id @default(cuid())
  orderNumber         String         @unique
  customerId          String?
  cashierId           String?
  branchId            String
  addressId           String?
  couponId            String?
  status              OrderStatus    @default(PENDING)
  channel             OrderChannel   @default(ONLINE)
  serviceType         ServiceType    @default(DELIVERY)
  customerName        String?
  customerPhone       String?
  foodpandaOrderNumber String?
  paymentMethod       PaymentMethod
  paymentStatus       PaymentStatus  @default(PENDING)
  subtotal            Decimal        @db.Decimal(10, 2)
  taxRate             Decimal        @db.Decimal(5, 2)
  taxAmount           Decimal        @db.Decimal(10, 2)
  deliveryFee         Decimal        @db.Decimal(10, 2)
  discountAmount      Decimal        @db.Decimal(10, 2)
  manualDiscountType  DiscountType?
  manualDiscountValue Decimal?       @db.Decimal(10, 2)
  cashReceivedAmount  Decimal?       @db.Decimal(10, 2)
  changeDueAmount     Decimal?       @db.Decimal(10, 2)
  totalAmount         Decimal        @db.Decimal(10, 2)
  expectedDeliveryAt  DateTime?
  deliveryInstructions String?
  placedAt            DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  customer            User?          @relation(fields: [customerId], references: [id])
  branch              Branch         @relation(fields: [branchId], references: [id])
  address             Address?       @relation(fields: [addressId], references: [id])
  coupon              Coupon?        @relation(fields: [couponId], references: [id])
  items               OrderItem[]
}

model OrderItem {
  id           String          @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  customDescription String?
  quantity     Int
  unitPrice    Decimal         @db.Decimal(10, 2)
  note         String?
  createdAt    DateTime        @default(now())
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product?        @relation(fields: [productId], references: [id])
  addOns       OrderItemAddOn[]
  bundleComponents OrderItemBundleComponent[]
}

model OrderItemAddOn {
  id          String      @id @default(cuid())
  orderItemId String
  optionId    String
  optionName  String
  priceDelta  Decimal     @db.Decimal(10, 2)
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option      AddOnOption @relation(fields: [optionId], references: [id])
}

model OrderItemBundleComponent {
  id                    String    @id @default(cuid())
  orderItemId           String
  productId             String?
  componentProductName   String
  quantity              Int
  unitPrice             Decimal   @db.Decimal(10, 2) @default(0)
  orderItem             OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product               Product?  @relation("OrderItemBundleComponentProduct", fields: [productId], references: [id], onDelete: SetNull)
}

model Favorite {
  userId     String
  productId  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  rating     Int
  title      String?
  body       String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String           @id @default(cuid())
  userId     String?
  type       NotificationType
  title      String
  message    String
  metadata   Json?
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Supplier {
  id          String             @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  notes       String?
  ingredients Ingredient[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Ingredient {
  id            String              @id @default(cuid())
  supplierId    String?
  name          String
  sku           String              @unique
  unit          String
  type          String              @default("RAW")
  isActive      Boolean             @default(true)
  reorderLevel  Decimal             @db.Decimal(10, 2)
  costPerUnit   Decimal             @db.Decimal(10, 2)
  caloriesPerUnit Decimal            @db.Decimal(10, 2) @default(0)
  supplier      Supplier?           @relation(fields: [supplierId], references: [id])
  branchLevels  BranchInventory[]
  productUsage  ProductIngredient[]
  preparedComponents IngredientComponent[] @relation("PreparedIngredient")
  usedInPreparedItems IngredientComponent[] @relation("ComponentIngredient")
  packagingRuleUsage PackagingRule[] @relation("PackagingRuleIngredient")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model BranchInventory {
  id             String                 @id @default(cuid())
  branchId       String
  ingredientId   String
  quantityOnHand Decimal                @db.Decimal(10, 2)
  lowStockAlert  Boolean                @default(false)
  branch         Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredient     Ingredient             @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  transactions   InventoryTransaction[]

  @@unique([branchId, ingredientId])
}

model InventoryTransaction {
  id               String                   @id @default(cuid())
  branchInventoryId String
  actorId          String?
  type             InventoryTransactionType
  quantity         Decimal                  @db.Decimal(10, 2)
  balanceAfter     Decimal                  @db.Decimal(10, 2)
  referenceType    String?
  referenceId      String?
  note             String?
  vendorName       String?
  purchaseDate     DateTime?
  purchaseCost     Decimal?                 @db.Decimal(10, 2)
  wastageReason    String?
  editedAt         DateTime?
  editedById       String?
  editHistory      Json?
  createdAt        DateTime                 @default(now())
  branchInventory  BranchInventory          @relation(fields: [branchInventoryId], references: [id], onDelete: Cascade)
  actor            User?                    @relation("InventoryActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model ProductIngredient {
  productId      String
  ingredientId   String
  quantityNeeded Decimal    @db.Decimal(10, 2)
  product        Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([productId, ingredientId])
}

model PackagingRule {
  id                    String     @id @default(cuid())
  productId             String?
  categoryId            String?
  serviceType           String     @default("DEFAULT")
  packagingIngredientId String
  quantityMode          String     @default("FIXED")
  quantity              Decimal    @db.Decimal(10, 2)
  itemStep              Int?
  product               Product?   @relation(fields: [productId], references: [id], onDelete: Cascade)
  category              Category?  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  packagingIngredient   Ingredient @relation("PackagingRuleIngredient", fields: [packagingIngredientId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([categoryId])
  @@index([serviceType])
  @@index([packagingIngredientId])
}

model IngredientComponent {
  parentIngredientId    String
  componentIngredientId String
  quantityNeeded        Decimal    @db.Decimal(10, 2)
  parentIngredient      Ingredient @relation("PreparedIngredient", fields: [parentIngredientId], references: [id], onDelete: Cascade)
  componentIngredient   Ingredient @relation("ComponentIngredient", fields: [componentIngredientId], references: [id], onDelete: Cascade)

  @@id([parentIngredientId, componentIngredientId])
}

model Expense {
  id            String   @id @default(cuid())
  branchId      String
  createdById   String?
  title         String
  category      String
  amount        Decimal  @db.Decimal(10, 2)
  paymentSource String   @default("CASH")
  expenseDate   DateTime
  vendor        String?
  billReference String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy     User?    @relation("ExpenseActor", fields: [createdById], references: [id], onDelete: SetNull)
}

model MoneyTransfer {
  id           String   @id @default(cuid())
  branchId     String
  fromSource   String
  toSource     String
  amount       Decimal  @db.Decimal(10, 2)
  transferDate DateTime
  note         String?
  createdById  String?
  createdAt    DateTime @default(now())
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy    User?    @relation("MoneyTransferActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([branchId, transferDate])
}

model DailyClosing {
  id                 String   @id @default(cuid())
  branchId           String
  closingDate        DateTime
  cashExpected       Decimal  @db.Decimal(10, 2)
  cashCounted        Decimal  @db.Decimal(10, 2)
  easypaisaExpected  Decimal  @db.Decimal(10, 2)
  easypaisaCounted   Decimal  @db.Decimal(10, 2)
  jazzcashExpected   Decimal  @db.Decimal(10, 2)
  jazzcashCounted    Decimal  @db.Decimal(10, 2)
  note               String?
  closedById         String?
  createdAt          DateTime @default(now())
  branch             Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  closedBy           User?    @relation("DailyClosingActor", fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([branchId, closingDate])
}

model Loan {
  id             String          @id @default(cuid())
  branchId       String
  lenderName     String
  amount         Decimal         @db.Decimal(10, 2)
  receivedSource String
  loanDate       DateTime
  note           String?
  createdById    String?
  createdAt      DateTime        @default(now())
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy      User?           @relation("LoanActor", fields: [createdById], references: [id], onDelete: SetNull)
  repayments     LoanRepayment[]

  @@index([branchId, loanDate])
  @@index([receivedSource])
}

model LoanRepayment {
  id          String   @id @default(cuid())
  loanId      String
  branchId    String
  amount      Decimal  @db.Decimal(10, 2)
  paidFrom    String
  paymentDate DateTime
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("LoanRepaymentActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([loanId])
  @@index([branchId, paymentDate])
  @@index([paidFrom])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  payload    Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model Setting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CmsContent {
  id          String        @id @default(cuid())
  key         String        @unique
  title       String
  status      ContentStatus @default(PUBLISHED)
  content     Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
